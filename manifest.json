{
  "manifest_version": 3,
  "name": "IKEA UK Gmail Code Autofiller",
  "version": "2.0",
  "description": "Fetches IKEA login codes from Google Apps Script.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png" 
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "512": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ikea-uk-202603310745@yourdomain.local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}